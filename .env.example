DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_pos?schema=public"
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=3000
NODE_ENV="development"
LOG_LEVEL="debug"

# Where uploaded product/category images are persisted. Resolved relative to
# the process CWD when not absolute. Served read-only at /uploads/*.
UPLOAD_DIR="./uploads"
# Per-file size limit in bytes for image uploads (2 MiB by default).
UPLOAD_MAX_BYTES=2097152
