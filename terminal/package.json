{
  "name": "restaurant-pos-terminal",
  "private": true,
  "version": "0.1.0",
  "description": "POS Terminal for the Restaurant POS — cashier station with ESC/POS printing and order management.",
  "author": "Restaurant POS",
  "homepage": "https://github.com/d4not/Restaurant-POS",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env ELECTRON_DEV=1 electron .",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "build:renderer": "tsc -b && vite build",
    "build": "npm run build:renderer && electron-builder",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "lint": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@thiagoelg/node-printer": "^0.6.2",
    "node-thermal-printer": "^4.6.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.3",
    "vite": "^8.0.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.restaurantpos.terminal",
    "productName": "POS Terminal",
    "copyright": "Copyright © 2026 Restaurant POS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/tsconfig*.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-thermal-printer/**/*",
      "**/node_modules/@thiagoelg/node-printer/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "synopsis": "Restaurant POS terminal",
      "description": "Cashier terminal for the Restaurant POS — connects to a backend on the local network and drives ESC/POS printers.",
      "maintainer": "Restaurant POS <noreply@example.com>",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "POS Terminal"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "icon": "build/icon.png"
    }
  }
}
