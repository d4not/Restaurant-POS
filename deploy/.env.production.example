# Restaurant POS — production environment template
#
# Copy this file to /opt/restaurant-pos/.env on the server and fill in real values.
# NEVER commit the real .env to git. The path used by the systemd unit is
# /opt/restaurant-pos/.env (see pos-backend.service).

# --- Database ---------------------------------------------------------------
# Use a non-superuser role that owns the schema. Generate the password with:
#   openssl rand -base64 24
DATABASE_URL="postgresql://pos_app:CHANGE_ME@localhost:5432/restaurant_pos?schema=public"

# --- Auth -------------------------------------------------------------------
# Generate a long random secret. NEVER reuse a development value.
#   openssl rand -base64 48
JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_48_CHARS"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server -----------------------------------------------------------------
PORT=3000
NODE_ENV="production"
LOG_LEVEL="info"
