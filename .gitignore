node_modules/
dist/
dist-electron/
release/
coverage/
*.log

# Environment / secrets — never commit; only .example templates are tracked.
.env*
!.env.example
!.env*.example

# Database dumps — backups live on the server, never in git.
*.dump
*.sql.gz

# User-uploaded images (product photos, category covers). Path is configurable
# via UPLOAD_DIR; this matches the default. Backups live wherever the operator
# decides, not git.
uploads/

# OS / editor junk
.DS_Store
Thumbs.db

# Claude Code — ignore worktrees & local config, but track shared agent/command configs
.claude/*
!.claude/agents/
!.claude/commands/

# Claude Code local config (explicit, even though .claude/* already covers it)
.claude/settings.local.json
CLAUDE.local.md

# Per-session task queue (lessons.md IS tracked)
tasks/todo.md

# Personal / production seed data — not part of the public repo.
prisma/seed-local*.ts

# Local skill outputs (impeccable design critiques, etc.)
.impeccable/
