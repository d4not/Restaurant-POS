// Restaurant POS — full data model
// See SPEC.md for entity definitions and business rules.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Enums
// ============================================================================

enum BaseUnit {
  PIECE
  BOTTLE
  KG
  LITER
  BAG
  BOX
  UNIT
}

enum ContentUnit {
  ML
  L
  G
  KG
  OZ
  FL_OZ
}

enum PurchaseStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum InventoryCheckType {
  FULL
  PARTIAL
}

enum InventoryCheckStatus {
  IN_PROGRESS
  COMPLETED
}

enum WriteOffReason {
  EXPIRED
  DAMAGED
  SPILLED
  THEFT
  OTHER
}

// Categorises why a sent OrderItem was voided. The first three are post-send
// realities the kitchen cares about; BEFORE_PREP is the only code that does
// not represent waste (the kitchen hadn't started cooking yet, so ingredients
// weren't consumed). Reporting downstream uses this split to keep merma
// accounting honest.
enum VoidReasonCode {
  PRODUCT_CHANGE
  PRODUCT_DEFECT
  BEFORE_PREP
  OTHER
}

enum StockMovementType {
  PURCHASE
  SALE
  TRANSFER_IN
  TRANSFER_OUT
  WRITE_OFF
  ADJUSTMENT
  MANUFACTURE
}

enum ProductType {
  PRODUCT
  DISH
  PREPARATION
}

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  BARISTA
  WAITER
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

// NORMAL    — opened by a cashier+ with a counted opening_amount.
// PROVISIONAL — opened by a barista/waiter when no cashier is on site yet.
// The system flags PROVISIONAL shifts in the UI and forces the cashier to
// physically count cash before closing them. After a PROVISIONAL closes, a
// new NORMAL shift is opened with that counted amount as opening_amount.
enum CashRegisterKind {
  NORMAL
  PROVISIONAL
}

enum CashMovementType {
  CASH_IN
  CASH_OUT
}

// ShiftType drives the report/verification workflow added in the reports
// module. REGULAR is a normal cashier-opened shift; PROVISIONAL is opened by
// any authenticated employee when a cashier isn't available and must be
// verified by a manager+ after close. Coexists with the older `kind` column
// (NORMAL/PROVISIONAL) which still gates the existing singleton-shift logic;
// new code should read `type` and the two are kept in sync at write time.
enum ShiftType {
  REGULAR
  PROVISIONAL
}

enum DailyReportStatus {
  OPEN
  CLOSED
}

enum AlertType {
  CASH_SHORTAGE
  CASH_SURPLUS
  RECURRING_SHORTAGE
  EXCESSIVE_VOIDS
  EXCESSIVE_DISCOUNTS
  UNVERIFIED_PROVISIONAL
  LATE_VOID
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEOUT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  DAY_OFF
  LATE
}

enum ModifierGroupType {
  SWAP
  ADD
}

enum ModifierOverrideType {
  RATIO
  FIXED_QTY
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum TableShape {
  TABLE_RECT
  TABLE_CIRCLE
}

enum ZoneKind {
  DINE_IN
  TAKEOUT
}

enum DecorType {
  // Free-floating non-table elements painted on the floor canvas. BAR_COUNTER
  // is the long hatched rectangle (a bar/counter that doesn't host orders);
  // DECOR_PLANT is a small green dot used as visual flavor next to seating.
  // These have no operational meaning — they're layout-only.
  BAR_COUNTER
  DECOR_PLANT
}

// Sub-channel for TAKEOUT orders. The takeout zone hosts three independent
// flows; each can be toggled on/off in settings without affecting the others.
//   LOCAL          — walk-up customer waiting at the counter for pickup.
//   DELIVERY_LOCAL — order delivered by the restaurant's own driver.
//   DELIVERY_APP   — third-party platform (Uber Eats, DiDi Food, etc.). The
//                    integration with each platform lands later; for now this
//                    is a free-form bucket the cashier picks manually.
enum TakeoutChannel {
  LOCAL
  DELIVERY_LOCAL
  DELIVERY_APP
}

// ============================================================================
// Phase 6 — referenced throughout; declared first
// ============================================================================

model User {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  email             String   @unique
  pin               String
  password_hash     String
  role              UserRole
  active            Boolean  @default(true)
  // Phase 8 — payroll fields. weekly_salary is nullable so users without
  // payroll (e.g. owners, API clients) coexist with employees.
  weekly_salary     Decimal? @db.Decimal(14, 0)
  hire_date         DateTime?
  position          String?
  phone             String?
  emergency_contact String?
  notes             String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  purchases         Purchase[]
  transfers         Transfer[]
  inventory_checks  InventoryCheck[]
  write_offs        WriteOff[]
  cash_registers    CashRegister[]
  cash_registers_closed CashRegister[] @relation("CashRegisterClosedBy")
  cash_movements    CashMovement[]
  orders            Order[]
  orders_cancelled  Order[]             @relation("OrderCancelledBy")
  order_items_added   OrderItem[]       @relation("OrderItemAddedBy")
  order_items_voided  OrderItem[]       @relation("OrderItemVoidedBy")
  suggestions_created  Suggestion[]    @relation("SuggestionCreator")
  suggestions_reviewed Suggestion[]    @relation("SuggestionReviewer")
  attendance        Attendance[]        @relation("AttendanceEmployee")
  attendance_logs   Attendance[]        @relation("AttendanceRecorder")
  payroll_periods   PayrollPeriod[]     @relation("PayrollEmployee")
  payroll_approvals PayrollPeriod[]     @relation("PayrollApprover")
  payment_approvals Payment[]           @relation("PaymentApprover")
  // Reports/shifts module: shifts this user verified after a provisional
  // close, daily reports they closed, and alerts surfaced about their
  // activity.
  shifts_verified      CashRegister[] @relation("ShiftVerifier")
  daily_reports_closed DailyReport[]
  alerts               Alert[]

  @@index([email])
  @@map("users")
}

model Tax {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  rate       Decimal  @db.Decimal(6, 2)
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  products Product[]

  @@map("taxes")
}

// Generic key/value store for singleton configuration. The initial use is
// "default_tax_id" (which tax applies to a product when its own tax_id is null)
// — prices are tax-inclusive, so the default tax drives the base/tax split on
// products that don't override it. value is a string; modules that need
// typed access parse it on read.
model Setting {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique
  value      String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("settings")
}

// ============================================================================
// Phase 2 — Supplies Module
// ============================================================================

model SupplyCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  supplies Supply[]

  @@map("supply_categories")
}

model Supply {
  id               String       @id @default(uuid()) @db.Uuid
  barcode          String?      @unique
  name             String
  category_id      String       @db.Uuid
  base_unit        BaseUnit
  content_per_unit Decimal?     @db.Decimal(14, 4)
  content_unit     ContentUnit?
  average_cost     Decimal      @default(0) @db.Decimal(14, 4)
  last_cost        Decimal      @default(0) @db.Decimal(14, 4)
  active           Boolean      @default(true)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt
  deleted_at       DateTime?

  category              SupplyCategory        @relation(fields: [category_id], references: [id])
  purchase_packagings   PurchasePackaging[]
  storage_stocks        StorageStock[]
  tare_weight           TareWeight?
  purchase_items        PurchaseItem[]
  transfer_items        TransferItem[]
  inventory_check_items InventoryCheckItem[]
  write_offs            WriteOff[]
  stock_movements       StockMovement[]
  modifiers             Modifier[]
  recipe_items          RecipeItem[]
  products              Product[]
  product_modifications ProductModification[]

  @@index([category_id])
  @@index([active])
  @@index([deleted_at])
  @@map("supplies")
}

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  contact_name String?
  phone        String?
  email        String?
  address      String?
  credit_days  Int      @default(0)
  notes        String?
  active       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  purchase_packagings PurchasePackaging[]
  purchases           Purchase[]

  @@map("suppliers")
}

model PurchasePackaging {
  id                String   @id @default(uuid()) @db.Uuid
  supply_id         String   @db.Uuid
  supplier_id       String   @db.Uuid
  name              String
  units_per_package Decimal  @db.Decimal(14, 4)
  price_per_package Decimal? @db.Decimal(14, 0)
  is_primary        Boolean  @default(false)
  active            Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  supply         Supply         @relation(fields: [supply_id], references: [id])
  supplier       Supplier       @relation(fields: [supplier_id], references: [id])
  purchase_items PurchaseItem[]

  @@index([supply_id])
  @@index([supplier_id])
  @@index([supply_id, is_primary])
  @@map("purchase_packagings")
}

model Storage {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  address    String?
  active     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  storage_stocks        StorageStock[]
  purchases             Purchase[]
  transfers_from        Transfer[]           @relation("TransferFrom")
  transfers_to          Transfer[]           @relation("TransferTo")
  inventory_checks      InventoryCheck[]
  write_offs            WriteOff[]
  stock_movements       StockMovement[]
  deduction_rules       DeductionRule[]

  @@map("storages")
}

model StorageStock {
  id         String   @id @default(uuid()) @db.Uuid
  supply_id  String   @db.Uuid
  storage_id String   @db.Uuid
  quantity   Decimal  @default(0) @db.Decimal(14, 4)
  min_stock  Decimal? @db.Decimal(14, 4)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  supply  Supply  @relation(fields: [supply_id], references: [id])
  storage Storage @relation(fields: [storage_id], references: [id])

  @@unique([supply_id, storage_id])
  @@index([storage_id])
  @@map("storage_stocks")
}

model TareWeight {
  id                 String   @id @default(uuid()) @db.Uuid
  supply_id          String   @unique @db.Uuid
  empty_weight_grams Decimal  @db.Decimal(14, 4)
  full_weight_grams  Decimal  @db.Decimal(14, 4)
  net_content        Decimal  @db.Decimal(14, 4)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  supply Supply @relation(fields: [supply_id], references: [id])

  @@map("tare_weights")
}

model Purchase {
  id             String         @id @default(uuid()) @db.Uuid
  supplier_id    String         @db.Uuid
  storage_id     String         @db.Uuid
  date           DateTime
  status         PurchaseStatus @default(DRAFT)
  total          Decimal        @default(0) @db.Decimal(14, 0)
  payment_method String?
  notes          String?
  user_id        String         @db.Uuid
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  supplier Supplier       @relation(fields: [supplier_id], references: [id])
  storage  Storage        @relation(fields: [storage_id], references: [id])
  user     User           @relation(fields: [user_id], references: [id])
  items    PurchaseItem[]

  @@index([supplier_id])
  @@index([storage_id])
  @@index([user_id])
  @@index([status])
  @@index([date])
  @@map("purchases")
}

model PurchaseItem {
  id                 String   @id @default(uuid()) @db.Uuid
  purchase_id        String   @db.Uuid
  supply_id          String   @db.Uuid
  packaging_id       String?  @db.Uuid
  package_quantity   Decimal  @db.Decimal(14, 4)
  price_per_package  Decimal  @db.Decimal(14, 0)
  base_unit_quantity Decimal  @db.Decimal(14, 4)
  unit_cost          Decimal  @db.Decimal(14, 4)
  created_at         DateTime @default(now())

  purchase  Purchase           @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  supply    Supply             @relation(fields: [supply_id], references: [id])
  packaging PurchasePackaging? @relation(fields: [packaging_id], references: [id])

  @@index([purchase_id])
  @@index([supply_id])
  @@map("purchase_items")
}

model Transfer {
  id              String   @id @default(uuid()) @db.Uuid
  from_storage_id String   @db.Uuid
  to_storage_id   String   @db.Uuid
  date            DateTime
  notes           String?
  user_id         String   @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  from_storage Storage        @relation("TransferFrom", fields: [from_storage_id], references: [id])
  to_storage   Storage        @relation("TransferTo", fields: [to_storage_id], references: [id])
  user         User           @relation(fields: [user_id], references: [id])
  items        TransferItem[]

  @@index([from_storage_id])
  @@index([to_storage_id])
  @@index([user_id])
  @@index([date])
  @@map("transfers")
}

model TransferItem {
  id          String  @id @default(uuid()) @db.Uuid
  transfer_id String  @db.Uuid
  supply_id   String  @db.Uuid
  quantity    Decimal @db.Decimal(14, 4)

  transfer Transfer @relation(fields: [transfer_id], references: [id], onDelete: Cascade)
  supply   Supply   @relation(fields: [supply_id], references: [id])

  @@index([transfer_id])
  @@index([supply_id])
  @@map("transfer_items")
}

model InventoryCheck {
  id           String               @id @default(uuid()) @db.Uuid
  storage_id   String               @db.Uuid
  type         InventoryCheckType
  status       InventoryCheckStatus @default(IN_PROGRESS)
  date         DateTime
  user_id      String               @db.Uuid
  completed_at DateTime?
  created_at   DateTime             @default(now())
  updated_at   DateTime             @updatedAt

  storage Storage              @relation(fields: [storage_id], references: [id])
  user    User                 @relation(fields: [user_id], references: [id])
  items   InventoryCheckItem[]

  @@index([storage_id])
  @@index([user_id])
  @@index([status])
  @@index([date])
  @@map("inventory_checks")
}

model InventoryCheckItem {
  id              String  @id @default(uuid()) @db.Uuid
  check_id        String  @db.Uuid
  supply_id       String  @db.Uuid
  expected_qty    Decimal @db.Decimal(14, 4)
  actual_qty      Decimal @db.Decimal(14, 4)
  difference      Decimal @db.Decimal(14, 4)
  difference_cost Decimal @db.Decimal(14, 4)

  check  InventoryCheck @relation(fields: [check_id], references: [id], onDelete: Cascade)
  supply Supply         @relation(fields: [supply_id], references: [id])

  @@index([check_id])
  @@index([supply_id])
  @@map("inventory_check_items")
}

model WriteOff {
  id         String         @id @default(uuid()) @db.Uuid
  storage_id String         @db.Uuid
  supply_id  String         @db.Uuid
  quantity   Decimal        @db.Decimal(14, 4)
  reason     WriteOffReason
  notes      String?
  date       DateTime
  user_id    String         @db.Uuid
  created_at DateTime       @default(now())

  storage Storage @relation(fields: [storage_id], references: [id])
  supply  Supply  @relation(fields: [supply_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@index([storage_id])
  @@index([supply_id])
  @@index([user_id])
  @@index([date])
  @@map("write_offs")
}

model StockMovement {
  id             String            @id @default(uuid()) @db.Uuid
  supply_id      String            @db.Uuid
  storage_id     String            @db.Uuid
  type           StockMovementType
  quantity       Decimal           @db.Decimal(14, 4)
  reference_type String
  reference_id   String            @db.Uuid
  unit_cost      Decimal           @db.Decimal(14, 4)
  created_at     DateTime          @default(now())

  supply  Supply  @relation(fields: [supply_id], references: [id])
  storage Storage @relation(fields: [storage_id], references: [id])

  @@index([supply_id])
  @@index([storage_id])
  @@index([type])
  @@index([reference_type, reference_id])
  @@index([created_at])
  // Compound indexes for the window-scoped report queries in reports/service.ts
  // (variance + supply-movement) which always filter by supply_id or
  // storage_id plus a created_at range.
  @@index([supply_id, created_at])
  @@index([storage_id, created_at])
  @@map("stock_movements")
}

model DeductionRule {
  // station_id / pos_register_id are optional pointers.
  // Station and PosRegister models are not defined in Phase 2 — kept as
  // loose UUIDs so the rule table can exist without those FKs until later
  // phases introduce them. Enforce referential integrity in app logic for now.
  id              String   @id @default(uuid()) @db.Uuid
  station_id      String?  @db.Uuid
  pos_register_id String?  @db.Uuid
  storage_id      String   @db.Uuid
  created_at      DateTime @default(now())

  storage Storage @relation(fields: [storage_id], references: [id])

  @@index([station_id])
  @@index([pos_register_id])
  @@index([storage_id])
  @@map("deduction_rules")
}

// ============================================================================
// Phase 3 — Products Module
// ============================================================================

model ProductCategory {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  image_url      String?
  color          String?
  display_order  Int      @default(0)
  visible_in_pos Boolean  @default(true)
  parent_id      String?  @db.Uuid
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parent_id])
  @@map("product_categories")
}

model Product {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  type           ProductType
  category_id    String?     @db.Uuid
  station_id     String?     @db.Uuid
  sell_price     Decimal?    @db.Decimal(14, 0)
  recipe_cost    Decimal     @default(0) @db.Decimal(14, 4)
  food_cost_pct  Decimal     @default(0) @db.Decimal(8, 4)
  markup         Decimal     @default(0) @db.Decimal(10, 4)
  image_url      String?
  icon_color     String?
  display_order  Int         @default(0)
  active         Boolean     @default(true)
  allow_discount Boolean     @default(true)
  sold_by_weight Boolean     @default(false)
  barcode        String?     @unique
  tax_id         String?     @db.Uuid
  supply_id      String?     @db.Uuid
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  deleted_at     DateTime?

  category               ProductCategory?        @relation(fields: [category_id], references: [id])
  tax                    Tax?                    @relation(fields: [tax_id], references: [id])
  supply                 Supply?                 @relation(fields: [supply_id], references: [id])
  variants               ProductVariant[]
  modifier_groups        ProductModifierGroup[]
  modifications          ProductModification[]
  recipe                 Recipe?                 @relation("ProductRecipe")
  // When this product is a PREPARATION and is used as an ingredient in other recipes.
  recipe_items_as_prep   RecipeItem[]            @relation("RecipeItemPreparation")
  order_items            OrderItem[]
  modifier_overrides     ModifierProductOverride[]
  suggestions            Suggestion[]

  @@index([category_id])
  @@index([type])
  @@index([active])
  @@index([deleted_at])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid()) @db.Uuid
  product_id    String   @db.Uuid
  name          String
  sell_price    Decimal  @db.Decimal(14, 0)
  barcode       String?  @unique
  recipe_cost   Decimal  @default(0) @db.Decimal(14, 4)
  food_cost_pct Decimal  @default(0) @db.Decimal(8, 4)
  display_order Int      @default(0)
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  recipe  Recipe? @relation("VariantRecipe")
  order_items OrderItem[]

  @@index([product_id])
  @@map("product_variants")
}

model ModifierGroup {
  id            String            @id @default(uuid()) @db.Uuid
  name          String
  // SWAP: recipe lines link to this group via RecipeItem.modifier_group_id —
  // at deduction the selected modifier (or the group's is_default modifier, if
  // none was picked) provides the supply. ADD (default): modifiers deduct on
  // top of the recipe.
  type          ModifierGroupType @default(ADD)
  min_selection Int               @default(0)
  max_selection Int               @default(1)
  required      Boolean           @default(false)
  display_order Int               @default(0)
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt

  modifiers     Modifier[]
  product_links ProductModifierGroup[]
  recipe_items  RecipeItem[]           @relation("RecipeItemModifierGroup")

  @@map("modifier_groups")
}

model Modifier {
  id              String   @id @default(uuid()) @db.Uuid
  group_id        String   @db.Uuid
  name            String
  extra_price     Decimal  @default(0) @db.Decimal(14, 0)
  supply_id       String?  @db.Uuid
  supply_quantity Decimal? @db.Decimal(14, 4)
  supply_unit     String?
  // For SWAP modifiers: multiplier applied to the recipe line's quantity when
  // this modifier fills the slot. 1.0 means "same amount"; 0.75 → deduct 75%
  // of the recipe qty from this modifier's supply. Ignored for ADD modifiers
  // (they use the supply_quantity triplet as a fixed amount).
  ratio           Decimal  @default(1) @db.Decimal(10, 4)
  // SWAP groups must have exactly one modifier with is_default=true — the
  // fallback used when the customer doesn't pick anything from the group at
  // the POS. Ignored for ADD modifiers (they never default).
  is_default      Boolean  @default(false)
  active          Boolean  @default(true)
  display_order   Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  group  ModifierGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  supply Supply?       @relation(fields: [supply_id], references: [id])
  order_item_modifiers OrderItemModifier[]
  product_overrides    ModifierProductOverride[]

  @@index([group_id])
  @@index([supply_id])
  @@map("modifiers")
}

model ProductModifierGroup {
  id                String @id @default(uuid()) @db.Uuid
  product_id        String @db.Uuid
  modifier_group_id String @db.Uuid

  product        Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  modifier_group ModifierGroup @relation(fields: [modifier_group_id], references: [id], onDelete: Cascade)

  @@unique([product_id, modifier_group_id])
  @@index([product_id])
  @@index([modifier_group_id])
  @@map("product_modifier_groups")
}

model Recipe {
  id             String   @id @default(uuid()) @db.Uuid
  product_id     String?  @unique @db.Uuid
  variant_id     String?  @unique @db.Uuid
  // Preparation recipes produce `yield_quantity` of `yield_unit` — required
  // only when the recipe belongs to a PREPARATION product so that other
  // recipes referencing it can compute cost per unit of yield.
  yield_quantity Decimal? @db.Decimal(14, 4)
  yield_unit     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  product Product?        @relation("ProductRecipe", fields: [product_id], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation("VariantRecipe", fields: [variant_id], references: [id], onDelete: Cascade)
  items   RecipeItem[]

  @@map("recipes")
}

model RecipeItem {
  id                String   @id @default(uuid()) @db.Uuid
  recipe_id         String   @db.Uuid
  // Exactly one of supply_id, preparation_id, or modifier_group_id is set.
  // modifier_group_id makes the line a "slot" filled at sale time by the
  // selected SWAP modifier — or the group's is_default modifier when the
  // customer picks nothing. quantity/unit/waste_pct still drive the deduction;
  // the modifier's supply + ratio determine which supply is drawn and how much.
  supply_id         String?  @db.Uuid
  preparation_id    String?  @db.Uuid
  modifier_group_id String?  @db.Uuid
  quantity          Decimal  @db.Decimal(14, 4)
  unit              String
  waste_pct         Decimal  @default(0) @db.Decimal(6, 4)
  created_at        DateTime @default(now())

  recipe         Recipe         @relation(fields: [recipe_id], references: [id], onDelete: Cascade)
  supply         Supply?        @relation(fields: [supply_id], references: [id])
  preparation    Product?       @relation("RecipeItemPreparation", fields: [preparation_id], references: [id])
  modifier_group ModifierGroup? @relation("RecipeItemModifierGroup", fields: [modifier_group_id], references: [id])

  @@index([recipe_id])
  @@index([supply_id])
  @@index([preparation_id])
  @@index([modifier_group_id])
  @@map("recipe_items")
}

model ProductModification {
  id            String   @id @default(uuid()) @db.Uuid
  product_id    String   @db.Uuid
  name          String
  sell_price    Decimal  @db.Decimal(14, 0)
  barcode       String?  @unique
  supply_id     String?  @db.Uuid
  active        Boolean  @default(true)
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
  supply  Supply? @relation(fields: [supply_id], references: [id])

  @@index([product_id])
  @@index([supply_id])
  @@map("product_modifications")
}

// Per-product exception to a modifier's default deduction rule. The schema-spec
// reasoning: a Latte and a Frappe may share the "Almond Milk" modifier but need
// different amounts (e.g. 150ml vs 90ml). An override attaches to (product,
// modifier) and wins over the modifier's own ratio/quantity at deduction time.
model ModifierProductOverride {
  id                String               @id @default(uuid()) @db.Uuid
  product_id        String               @db.Uuid
  modifier_id       String               @db.Uuid
  override_type     ModifierOverrideType
  // RATIO override: multiplier applied to the recipe's original ingredient qty
  // (same semantics as Modifier.ratio, just product-scoped).
  override_ratio    Decimal?             @db.Decimal(10, 4)
  // FIXED_QTY override: absolute amount of the modifier's supply to deduct in
  // `override_unit`. Ratio is ignored when FIXED_QTY is set.
  override_quantity Decimal?             @db.Decimal(14, 4)
  override_unit     String?
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt

  product  Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  modifier Modifier @relation(fields: [modifier_id], references: [id], onDelete: Cascade)

  @@unique([product_id, modifier_id])
  @@index([product_id])
  @@index([modifier_id])
  @@map("modifier_product_overrides")
}

// ============================================================================
// Phase 7 — Orders, Payments & Cash Register
// ============================================================================

model CashRegister {
  id              String             @id @default(uuid()) @db.Uuid
  user_id         String             @db.Uuid
  // PROVISIONAL shifts are opened by floor staff (barista/waiter) when no
  // cashier is on site. They MUST be closed by a cashier+ with a counted
  // actual_amount before normal operations resume.
  kind            CashRegisterKind   @default(NORMAL)
  opened_at       DateTime           @default(now())
  closed_at       DateTime?
  // Cashier+ who closed this shift — for provisional shifts this is the
  // arriving cashier doing the count, distinct from user_id (the opener).
  closed_by_user_id String?         @db.Uuid
  opening_amount  Decimal             @db.Decimal(14, 0)
  // expected_amount is maintained incrementally as cash payments, change-given
  // and CashMovements land. It's authoritative for the close-flow so the user
  // doesn't have to re-run a big aggregate query every time.
  expected_amount Decimal             @default(0) @db.Decimal(14, 0)
  actual_amount   Decimal?            @db.Decimal(14, 0)
  difference      Decimal?            @db.Decimal(14, 0)
  status          CashRegisterStatus  @default(OPEN)
  notes           String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt

  // Reports module additions. `type` mirrors `kind` for the new workflow
  // (REGULAR vs PROVISIONAL) and is the column the reports/verification code
  // reads. `parent_shift_id` points a PROVISIONAL shift back at the REGULAR
  // shift it was opened against (the cashier inherits the parent's drawer).
  // `requires_verification` flips on for provisionals; the verified_* trio
  // is filled when a manager+ signs off on the closed provisional.
  // `daily_report_id` ties the shift into the consolidated DailyReport once
  // the day is closed.
  type                  ShiftType    @default(REGULAR)
  parent_shift_id       String?      @db.Uuid
  parent_shift          CashRegister?  @relation("ShiftHierarchy", fields: [parent_shift_id], references: [id])
  child_shifts          CashRegister[] @relation("ShiftHierarchy")
  requires_verification Boolean      @default(false)
  verified_by_id        String?      @db.Uuid
  verified_by           User?        @relation("ShiftVerifier", fields: [verified_by_id], references: [id])
  verified_at           DateTime?
  verification_notes    String?
  daily_report_id       String?      @db.Uuid
  daily_report          DailyReport? @relation(fields: [daily_report_id], references: [id])
  shift_report          ShiftReport?

  user            User           @relation(fields: [user_id], references: [id])
  closed_by       User?          @relation("CashRegisterClosedBy", fields: [closed_by_user_id], references: [id])
  orders          Order[]
  cash_movements  CashMovement[]

  @@index([user_id])
  @@index([status])
  @@index([opened_at])
  @@index([kind])
  @@index([type])
  @@index([parent_shift_id])
  @@index([daily_report_id])
  @@map("cash_registers")
}

model CashMovement {
  id          String           @id @default(uuid()) @db.Uuid
  register_id String           @db.Uuid
  type        CashMovementType
  amount      Decimal          @db.Decimal(14, 0)
  reason      String
  user_id     String           @db.Uuid
  created_at  DateTime         @default(now())

  register CashRegister @relation(fields: [register_id], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [user_id], references: [id])

  @@index([register_id])
  @@index([user_id])
  @@index([type])
  @@map("cash_movements")
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  register_id     String      @db.Uuid
  order_number    Int
  status          OrderStatus @default(OPEN)
  order_type      OrderType
  // Required when order_type=TAKEOUT, NULL for DINE_IN. Service-layer
  // enforcement only — Postgres can't express the conditional easily and
  // adding a CHECK constraint conflicts with existing rows.
  takeout_channel TakeoutChannel?
  // Customer + delivery snapshots for takeout orders. All optional — the
  // cashier fills the relevant subset for the active channel:
  //   LOCAL          → customer_name (so the comanda prints "for John")
  //   DELIVERY_LOCAL → customer_name + customer_phone + delivery_address +
  //                    delivery_reference + delivery_driver_name
  //   DELIVERY_APP   → delivery_app + delivery_app_order_id
  // The fields stay populated even if the channel changes — the snapshot is
  // historical. Service-layer code clears every field when order_type flips
  // back to DINE_IN.
  customer_name           String?
  customer_phone          String?
  delivery_address        String?
  delivery_reference      String?
  delivery_driver_name    String?
  delivery_app            String?
  delivery_app_order_id   String?
  // Optional dine-in table assignment. Multiple OPEN orders on the same table
  // are permitted (group ordering); the table is freed only after the LAST
  // open order is PAID or CANCELLED. ON DELETE SET NULL so deleting the table
  // doesn't lose order history.
  table_id        String?     @db.Uuid
  subtotal        Decimal     @default(0) @db.Decimal(14, 0)
  tax_amount      Decimal     @default(0) @db.Decimal(14, 0)
  discount_amount Decimal     @default(0) @db.Decimal(14, 0)
  discount_reason String?
  total           Decimal     @default(0) @db.Decimal(14, 0)
  notes           String?
  user_id         String      @db.Uuid
  // Keeps the daily-reset order_number unique — two orders on the same date
  // cannot share the same number. Date stored at midnight UTC.
  order_date      DateTime    @db.Date
  // Waiter-to-cashier "Request Edit" flag. Waiters can't delete items or apply
  // discounts; when they need one, they flip this flag with an optional reason
  // so the cashier's OrdersList highlights the order. The cashier clears it
  // after resolving.
  needs_attention  Boolean    @default(false)
  attention_reason String?
  // Audit fields populated when an order is moved to CANCELLED. The cashier
  // must enter a free-text reason (>=5 chars) and re-confirm with their PIN
  // before the cancel is accepted.
  cancel_reason       String?
  cancelled_by_user_id String?  @db.Uuid
  cancelled_at         DateTime?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  register CashRegister @relation(fields: [register_id], references: [id])
  user     User         @relation(fields: [user_id], references: [id])
  table    Table?       @relation(fields: [table_id], references: [id])
  cancelled_by User?    @relation("OrderCancelledBy", fields: [cancelled_by_user_id], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@unique([order_date, order_number])
  @@index([register_id])
  @@index([user_id])
  @@index([status])
  @@index([order_type])
  @@index([table_id])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  order_id        String   @db.Uuid
  product_id      String   @db.Uuid
  variant_id      String?  @db.Uuid
  quantity        Int      @default(1)
  unit_price      Decimal  @db.Decimal(14, 0)
  modifiers_price Decimal  @default(0) @db.Decimal(14, 0)
  line_total      Decimal  @db.Decimal(14, 0)
  // Per-item tax snapshot. tax_rate is captured from the product's linked Tax
  // at the moment the item is added — later edits to the tax row don't rewrite
  // historical orders. Prices are tax-INCLUSIVE: line_total is what the
  // customer pays for the line; base_amount is the revenue portion and
  // tax_amount is the tax portion extracted out of line_total.
  //   base_amount = round(line_total / (1 + tax_rate/100))
  //   tax_amount  = line_total - base_amount
  // All default to 0 for tax-exempt products (base_amount = line_total).
  tax_rate        Decimal  @default(0) @db.Decimal(6, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(14, 0)
  base_amount     Decimal  @default(0) @db.Decimal(14, 0)
  notes           String?
  // Kitchen routing — set when the cashier/waiter fires the order to the
  // kitchen printer. Once true, the item is not reprinted on subsequent
  // "Send to Kitchen" actions (only newly-added items go through). sent_at
  // is null until the first send and stays put through later edits.
  sent_to_kitchen Boolean  @default(false)
  sent_at         DateTime?
  // The waiter/cashier who put this line on the ticket. Optional so
  // pre-existing items (added by the admin panel before terminal rollout)
  // and seeded test orders don't violate the constraint.
  added_by        String?  @db.Uuid
  // Soft-delete (void) audit. Items that have been sent to the kitchen are
  // never hard-deleted — instead voided_at is stamped so the ticket can show
  // the line struck-through, the cashier can Restore it, and the next
  // Send to Kitchen prints a "REMOVED" notification. void_printed_at is set
  // once the kitchen has been told; restoring an item whose void was already
  // printed clears sent_to_kitchen so the kitchen sees a fresh request.
  voided_at        DateTime?
  voided_by        String?  @db.Uuid
  // Categorical code chosen by the cashier from the void modal. Required at
  // the service layer when sent_to_kitchen=true (along with void_reason ≥ 3
  // chars); null for unsent free-cancel paths and for legacy rows voided
  // before this column existed.
  void_reason_code VoidReasonCode?
  void_reason      String?
  void_printed_at  DateTime?
  created_at      DateTime @default(now())

  order      Order               @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product             @relation(fields: [product_id], references: [id])
  variant    ProductVariant?     @relation(fields: [variant_id], references: [id])
  added_by_user User?            @relation("OrderItemAddedBy", fields: [added_by], references: [id])
  voided_by_user User?           @relation("OrderItemVoidedBy", fields: [voided_by], references: [id])
  modifiers  OrderItemModifier[]

  @@index([order_id])
  @@index([product_id])
  @@index([variant_id])
  @@index([added_by])
  @@index([order_id, sent_to_kitchen])
  @@index([voided_at])
  @@index([order_id, voided_at])
  @@map("order_items")
}

model OrderItemModifier {
  id            String @id @default(uuid()) @db.Uuid
  order_item_id String @db.Uuid
  modifier_id   String @db.Uuid
  // Snapshots — these survive menu edits so order history stays accurate.
  name          String
  extra_price   Decimal @db.Decimal(14, 0)

  order_item OrderItem @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
  modifier   Modifier  @relation(fields: [modifier_id], references: [id])

  @@index([order_item_id])
  @@index([modifier_id])
  @@map("order_item_modifiers")
}

model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  order_id             String        @db.Uuid
  method               PaymentMethod
  amount               Decimal       @db.Decimal(14, 0)
  change_amount        Decimal       @default(0) @db.Decimal(14, 0)
  reference            String?
  // Set when a waiter/barista initiated the payment with a cashier+'s PIN.
  // Null when the JWT user already had cashier+ rights.
  approved_by_user_id  String?       @db.Uuid
  created_at           DateTime      @default(now())

  order       Order @relation(fields: [order_id], references: [id], onDelete: Cascade)
  approved_by User? @relation("PaymentApprover", fields: [approved_by_user_id], references: [id])

  @@index([order_id])
  @@index([method])
  @@index([approved_by_user_id])
  @@map("payments")
}

// ============================================================================
// Phase 7b — Shift Reports, Daily Reports, Alerts
// ============================================================================

// Immutable snapshot generated inside the closeRegister() transaction. Every
// field is denormalised so the report survives later edits to the user, the
// orders, the menu, etc. Money is centavos as integers (matches the rest of
// the system). sales_by_category and top_products are Json because their
// shape is report-specific and never queried relationally.
model ShiftReport {
  id                String    @id @default(uuid()) @db.Uuid

  cash_register_id  String    @unique @db.Uuid
  cash_register     CashRegister @relation(fields: [cash_register_id], references: [id])

  user_id           String    @db.Uuid
  user_name         String
  user_role         String
  shift_type        ShiftType
  opened_at         DateTime
  closed_at         DateTime

  gross_sales       Int       @default(0)
  discounts         Int       @default(0)
  comps             Int       @default(0)
  void_total        Int       @default(0)
  void_count        Int       @default(0)
  net_sales         Int       @default(0)
  tax_collected     Int       @default(0)

  total_tickets     Int       @default(0)
  avg_ticket        Int       @default(0)

  cash_sales        Int       @default(0)
  card_sales        Int       @default(0)
  transfer_sales    Int       @default(0)
  other_sales       Int       @default(0)

  opening_amount    Int       @default(0)
  cash_in           Int       @default(0)
  cash_out          Int       @default(0)
  expected_cash     Int       @default(0)
  actual_cash       Int?
  cash_variance     Int?

  sales_by_category Json      @default("[]")
  top_products      Json      @default("[]")

  verified_by_id    String?   @db.Uuid
  verified_by_name  String?
  verified_at       DateTime?

  alerts            Alert[]

  created_at        DateTime  @default(now())

  @@index([user_id])
  @@index([created_at])
  @@map("shift_reports")
}

// Consolidated end-of-day report. One row per calendar day (date is unique,
// stored at midnight UTC). folio is a global auto-incrementing counter — the
// frontend prefixes "Z-". Status only flows OPEN → CLOSED; the close action
// is gated on no shift still being open for that day.
model DailyReport {
  id                  String            @id @default(uuid()) @db.Uuid
  date                DateTime          @unique @db.Date
  folio               Int               @default(autoincrement())
  status              DailyReportStatus @default(OPEN)

  gross_sales         Int       @default(0)
  discounts           Int       @default(0)
  comps               Int       @default(0)
  void_total          Int       @default(0)
  void_count          Int       @default(0)
  net_sales           Int       @default(0)
  tax_collected       Int       @default(0)

  total_tickets       Int       @default(0)
  avg_ticket          Int       @default(0)

  cash_sales          Int       @default(0)
  card_sales          Int       @default(0)
  transfer_sales      Int       @default(0)
  other_sales         Int       @default(0)

  total_opening_amount Int      @default(0)
  total_cash_in       Int       @default(0)
  total_cash_out      Int       @default(0)
  total_expected_cash Int       @default(0)
  total_actual_cash   Int?
  total_cash_variance Int?

  sales_by_category   Json      @default("[]")
  top_products        Json      @default("[]")
  bottom_products     Json      @default("[]")
  sales_by_hour       Json      @default("[]")

  total_shifts        Int       @default(0)
  provisional_shifts  Int       @default(0)
  unverified_provisionals Int   @default(0)

  peak_hour           Int?
  slowest_hour        Int?

  shifts              CashRegister[]
  alerts              Alert[]

  // Snapshotted at close time so the printed report renders correctly even
  // if the operator changes the active language/currency afterwards. See
  // REPORTS-SPEC §2.4 and §5.1.
  currency            String    @default("MXN")
  language            String    @default("es")

  // Optional bills/coins breakdown counted by the manager. JSON keys are
  // denominations in centavos (as strings); values are counts. The sum of
  // (denomination × count) must match total_actual_cash when present.
  denomination_breakdown Json?

  closed_by_id        String?   @db.Uuid
  closed_by           User?     @relation(fields: [closed_by_id], references: [id])
  closed_at           DateTime?
  notes               String?
  // Final cash verdict the manager writes at close time ("Corte cuadrado",
  // "Faltante de $30, se descontará"). Separate from notes — notes are
  // operational context, resolution is the sign-off.
  resolution          String?

  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([date])
  @@index([status])
  @@map("daily_reports")
}

// Auto-generated signal raised at shift close or day close when the
// thresholds in `settings` (alert_*) are breached. Severity grades urgency;
// `data` is a free-form JSON payload with the numbers behind the message
// (e.g. {variance: -3050, threshold: 2000}). Resolved by a manager+ with a
// short note for the audit trail.
model Alert {
  id              String        @id @default(uuid()) @db.Uuid
  type            AlertType
  severity        AlertSeverity
  message         String
  data            Json          @default("{}")

  user_id         String?       @db.Uuid
  user            User?         @relation(fields: [user_id], references: [id])

  shift_report_id String?       @db.Uuid
  shift_report    ShiftReport?  @relation(fields: [shift_report_id], references: [id])
  daily_report_id String?       @db.Uuid
  daily_report    DailyReport?  @relation(fields: [daily_report_id], references: [id])

  resolved        Boolean       @default(false)
  resolved_by_id  String?       @db.Uuid
  resolved_at     DateTime?
  resolution      String?

  created_at      DateTime      @default(now())

  @@index([type, resolved])
  @@index([severity])
  @@index([user_id])
  @@index([shift_report_id])
  @@index([daily_report_id])
  @@map("alerts")
}

// ============================================================================
// Phase 8 — Employees & Payroll
// ============================================================================

model Attendance {
  id          String           @id @default(uuid()) @db.Uuid
  user_id     String           @db.Uuid
  date        DateTime         @db.Date
  status      AttendanceStatus
  reason      String?
  // is_paid only meaningful for ABSENT; for PRESENT/LATE/DAY_OFF it's
  // informational. Kept as a column so the payroll calculation can treat
  // any row uniformly without branching on status.
  is_paid     Boolean          @default(true)
  notes       String?
  recorded_by String           @db.Uuid
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  user     User @relation("AttendanceEmployee", fields: [user_id], references: [id])
  recorder User @relation("AttendanceRecorder", fields: [recorded_by], references: [id])

  @@unique([user_id, date])
  @@index([date])
  @@index([status])
  @@map("attendance")
}

model PayrollPeriod {
  id              String        @id @default(uuid()) @db.Uuid
  user_id         String        @db.Uuid
  week_start      DateTime      @db.Date
  week_end        DateTime      @db.Date
  days_expected   Int           @default(6)
  days_worked     Int           @default(0)
  days_absent     Int           @default(0)
  paid_absences   Int           @default(0)
  unpaid_absences Int           @default(0)
  gross_pay       Decimal       @default(0) @db.Decimal(14, 0)
  deductions      Decimal       @default(0) @db.Decimal(14, 0)
  bonuses         Decimal       @default(0) @db.Decimal(14, 0)
  net_pay         Decimal       @default(0) @db.Decimal(14, 0)
  status          PayrollStatus @default(DRAFT)
  notes           String?
  approved_by     String?       @db.Uuid
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  user     User  @relation("PayrollEmployee", fields: [user_id], references: [id])
  approver User? @relation("PayrollApprover", fields: [approved_by], references: [id])

  @@unique([user_id, week_start])
  @@index([status])
  @@index([week_start])
  @@map("payroll_periods")
}

// ============================================================================
// Phase 10 — Zones & Tables (dine-in floor management)
// ============================================================================

model Zone {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  display_order Int      @default(0)
  // DINE_IN: regular zone hosting positioned tables on the floor canvas.
  // TAKEOUT: virtual zone that never holds tables — its floor-plan tab swaps
  // the canvas for a list of active TAKEOUT/delivery orders. The system
  // permits at most one TAKEOUT zone (enforced by a partial unique index).
  kind          ZoneKind @default(DINE_IN)
  // Floor-canvas geometry — the zone is rendered as a dashed-bordered box at
  // these coordinates and sizes, with its tables/decor positioned relative to
  // its top-left corner. TAKEOUT zones ignore these (they render as a list).
  pos_x         Int      @default(0)
  pos_y         Int      @default(0)
  width         Int      @default(480)
  height        Int      @default(320)
  active        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tables       Table[]
  // Floor-canvas free-floating text labels scoped to this zone. Cascade delete
  // so wiping a zone doesn't leave orphaned labels on the canvas.
  zone_labels  ZoneLabel[]
  floor_decor  FloorDecor[]

  @@map("zones")
}

model Table {
  id         String      @id @default(uuid()) @db.Uuid
  zone_id    String      @db.Uuid
  // Display number within the zone — e.g. "Table 3" in the Terrace.
  // Uniqueness is per-zone so two zones can each have a "1".
  number     Int
  capacity   Int         @default(2)
  // Set to OCCUPIED on the first order created against the table; reverted to
  // AVAILABLE only when no OPEN orders remain (so group orders share a table
  // without flipping the badge between settles). RESERVED is set manually.
  status     TableStatus @default(AVAILABLE)
  // Floor-plan visual state. pos_x/pos_y are pixel coordinates within the
  // canvas container; width/height are the rendered box size. shape controls
  // the render primitive (rounded rect vs circle). label overrides the numeric
  // display when the restaurant uses named tables (e.g. "Patio 3"). rotation
  // lets long rectangles sit flush against walls at arbitrary angles.
  pos_x      Int         @default(0)
  pos_y      Int         @default(0)
  width      Int         @default(120)
  height     Int         @default(120)
  shape      TableShape  @default(TABLE_RECT)
  label      String?
  rotation   Int         @default(0)
  active     Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  zone        Zone         @relation(fields: [zone_id], references: [id], onDelete: Cascade)
  orders      Order[]
  suggestions Suggestion[]

  @@unique([zone_id, number])
  @@index([zone_id])
  @@index([status])
  @@map("tables")
}

// ─── Suggestion approval queue ────────────────────────────────────────────
// Cashiers can propose schema-shape changes (new table, new product, layout
// move) but admin holds the gate. The suggestion stores the *proposed* change
// as an opaque JSON payload; on approval the matching service re-parses the
// payload through its own Zod schema and executes the operation. This keeps
// validation logic in one place per resource and makes the suggestion table
// dumb storage.
enum SuggestionType {
  TABLE_CREATE
  TABLE_UPDATE
  TABLE_DELETE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Suggestion {
  id      String           @id @default(uuid()) @db.Uuid
  type    SuggestionType
  status  SuggestionStatus @default(PENDING)
  // Free-form JSON describing the proposed change. Validated against a Zod
  // schema specific to each `type` at create-time and again at approve-time
  // so a stale payload (e.g. table now belongs to a deleted zone) fails the
  // approve cleanly instead of corrupting state.
  payload Json
  // Optional human-readable note from the suggester ("table moved to make
  // room for the new bar"). Surfaced to admin when reviewing.
  note    String?

  // Targeting — populated only for UPDATE/DELETE so the admin UI can surface
  // a link to the live record. CREATE suggestions leave both null.
  target_table_id   String? @db.Uuid
  target_product_id String? @db.Uuid

  created_by  String   @db.Uuid
  reviewed_by String?  @db.Uuid
  // Optional admin note ("approved with capacity bumped to 4 by request").
  review_note String?
  reviewed_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  creator  User     @relation("SuggestionCreator",  fields: [created_by],  references: [id])
  reviewer User?    @relation("SuggestionReviewer", fields: [reviewed_by], references: [id])
  table    Table?   @relation(fields: [target_table_id],   references: [id], onDelete: SetNull)
  product  Product? @relation(fields: [target_product_id], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([created_by])
  @@index([reviewed_by])
  @@index([target_table_id])
  @@index([target_product_id])
  @@map("suggestions")
}

// Free-floating text labels rendered on the floor canvas. Unlike zone NAMES
// (stored on Zone itself and used as the tab label in the old grid view), these
// are decorative on-canvas elements: room names, wall markers, decorative
// hints ("High Bar", "Patio"). Positioned absolutely in the same coordinate
// space as Table. Cascade delete with Zone.
model ZoneLabel {
  id         String   @id @default(uuid()) @db.Uuid
  zone_id    String   @db.Uuid
  text       String
  pos_x      Int      @default(0)
  pos_y      Int      @default(0)
  width      Int      @default(200)
  height     Int      @default(48)
  font_size  Int      @default(24)
  rotation   Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  zone Zone @relation(fields: [zone_id], references: [id], onDelete: Cascade)

  @@index([zone_id])
  @@map("zone_labels")
}

// Decorative non-interactive elements on the floor canvas (bar counters, plants)
// scoped to a zone. Cascade delete keeps the canvas tidy when a zone is wiped.
// Soft-deleted via `active=false` so historical floor snapshots remain valid;
// the floors endpoint filters to active=true.
model FloorDecor {
  id         String    @id @default(uuid()) @db.Uuid
  zone_id    String    @db.Uuid
  type       DecorType
  pos_x      Int       @default(0)
  pos_y      Int       @default(0)
  width      Int       @default(80)
  height     Int       @default(50)
  label      String?
  rotation   Int       @default(0)
  active     Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  zone Zone @relation(fields: [zone_id], references: [id], onDelete: Cascade)

  @@index([zone_id])
  @@map("floor_decor")
}
